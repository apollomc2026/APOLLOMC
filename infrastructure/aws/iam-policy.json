{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3ApolloAccess",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::apollo-outputs-private",
        "arn:aws:s3:::apollo-outputs-private/*"
      ]
    },
    {
      "Sid": "SESApolloSend",
      "Effect": "Allow",
      "Action": [
        "ses:SendEmail",
        "ses:SendRawEmail"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "ses:FromAddress": "missions@apollomc.ai"
        }
      }
    }
  ]
}
